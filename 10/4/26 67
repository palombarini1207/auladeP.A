        "\n",
        "#Entrada\n",
        "numero = int ( input(\"digite um numero: \"))\n",
        "\n",
        "# processamento ? saida\n",
        "\n",
        "if numero % 2 == 0:\n",
        "\n",
        "  print (f\" o numero {numero} é par\")\n",
        "\n",
        "else:\n",
        "  print (f\" o numero {numero} é impar\")"
